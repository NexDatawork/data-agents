# OpenGraph AI local configuration template
#
# Copy this file to `.env.local` (preferred) or `.env` and replace the values
# with your own local secrets. Never commit the populated file.

# Required for the LLM-backed extractor and CLI.
OPENAI_API_KEY=your_openai_api_key_here

# Optional model override.
OPENAI_MODEL=gpt-4o-mini

# Optional future provider settings.
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
# AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT_NAME=your_deployment_name_here
# AZURE_OPENAI_API_VERSION=2024-02-15-preview