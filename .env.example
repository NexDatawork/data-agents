# OpenGraph AI local configuration template
#
# Copy this file to `.env.local` (preferred) or `.env` and replace the values
# with your own local secrets. Never commit the populated file.

# Required for the LLM-backed extractor and CLI.
OPENAI_API_KEY=your_openai_api_key_here

# Optional model override.
OPENAI_MODEL=gpt-4o-mini

# Optional future provider settings.
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
# AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT_NAME=your_deployment_name_here
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# -----------------------------
# GCP / Cloud Storage settings
# -----------------------------
# Required for `cli upload`, `extract tables-gcs`, and `graphdb from-gcs`.
GCP_PROJECT_ID=your_gcp_project_id
GCS_BUCKET=your_gcs_bucket_name

# Optional bucket prefixes used by commands.
GCS_PREFIX=opengraph-ai/input
GCS_OUTPUT_PREFIX=opengraph-ai/output

# Optional if you are not using gcloud ADC.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account-key.json

# -----------------------------
# Neo4j AuraDB settings
# -----------------------------
# Required for `graphdb push`, `graphdb pull`, and `graphdb from-gcs`.
NEO4J_URI=neo4j+s://<your-aura-instance>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Optional (defaults to `neo4j` in code if omitted).
NEO4J_DATABASE=neo4j

# Optional metadata only.
# AURA_INSTANCEID=your_aura_instance_id
# AURA_INSTANCENAME=your_aura_instance_name